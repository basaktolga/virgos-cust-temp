# Which venue this build serves — its slug (row) in the shared Virgo platform.
# A fork of this template only needs to set this; menu + branding come from the API.
VITE_VENUE_SLUG=

# Optional: for account venues (Mode A/B) set this so the login screen shows
# first, before the menu loads. Leave blank for anonymous (no login).
#   account_delivery  (Mode A — scan destination at checkout)
#   account_table     (Mode B — table session + split pay)
VITE_ORDER_MODE=
